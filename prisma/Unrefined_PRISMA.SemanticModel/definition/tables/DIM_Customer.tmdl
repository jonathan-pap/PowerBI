	column age
		dataType: int64
		formatString: 0
		lineageTag: 5620c72b-b9c9-4816-9c2a-6ccec01044f5
		summarizeBy: none
		sourceColumn: Age

		annotation SummarizationSetBy = Automatic

	column age_band =
			SWITCH(
			    TRUE(),
			    DIM_Customer[age] >= 18 && DIM_Customer[age] <= 29, "18-29",
			    DIM_Customer[age] >= 30 && DIM_Customer[age] <= 44, "30-44",
			    DIM_Customer[age] >= 45 && DIM_Customer[age] <= 59, "45-59",
			    DIM_Customer[age] >= 60 && DIM_Customer[age] <= 74, "60-74",
			    DIM_Customer[age] >= 75,                        "75+",
			    "Unknown"
			)
		dataType: string
		lineageTag: f31a399b-3bba-4829-91d5-93ac97213394
		summarizeBy: none
		sortByColumn: age_band_sort

	column age_band_sort =
			SWITCH(
			    TRUE(),
			    DIM_Customer[age] >= 18 && DIM_Customer[age] <= 29, 1,
			    DIM_Customer[age] >= 30 && DIM_Customer[age] <= 44, 2,
			    DIM_Customer[age] >= 45 && DIM_Customer[age] <= 59, 3,
			    DIM_Customer[age] >= 60 && DIM_Customer[age] <= 74, 4,
			    DIM_Customer[age] >= 75,                        5,
			    99
			)
		dataType: int64
		isHidden
		lineageTag: ad82729f-7e03-4dfe-b04c-3f279087a7e4
		summarizeBy: none

	/// Four-level geographic drill-down for customer location analysis: Continent → Country → State → City.
	hierarchy Geography
		lineageTag: 07ae4e19-8d83-4ed4-99dc-5788344dd674

		/// Top level. Groups customers by continent (e.g. Europe, North America).
		level Continent
			lineageTag: 16856cfe-abc2-483c-9bc8-050b30040d1e
			column: continent

		/// Second level. Full country name within the selected continent.
		level Country
			lineageTag: b6eec68e-716e-49b1-9409-e4eea2b5aab7
			column: country

		/// Third level. State or region within the selected country.
		level State
			lineageTag: a741cd5b-f3ca-49ec-83dd-c7220320bb84
			column: state

		/// Lowest level. City within the selected state.
		level City
			lineageTag: d9990c9a-b040-49f3-a8eb-4a74272bbe24
			column: city

	partition DIM_Customer-bee8b62a-fee2-49b8-a0b6-5518e67a2d59 = m
		mode: import
		source =
				let
				    Source = Sql.Databases("Demo"),
				    #"Contoso" = Source{[Name="Contoso V2 1M"]}[Data],
				    dbo_Customer = #"Contoso"{[Schema="dbo",Item="Customer"]}[Data]
				in
				    dbo_Customer

	changedProperty = Name

	annotation PBI_ResultType = Table

