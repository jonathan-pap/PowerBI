	measure 'New Customers' =
			CALCULATE(
			    DISTINCTCOUNT( FCT_Sales[customer_key] ),
			    FILTER(
			        VALUES( FCT_Sales[customer_key] ),
			        VAR FirstPurchaseDate =
			            CALCULATE( MIN( FCT_Sales[order_date] ), ALL( 'DIM_Date' ) )
			        RETURN
			            FirstPurchaseDate >= MIN( 'DIM_Date'[date] ) &&
			            FirstPurchaseDate <= MAX( 'DIM_Date'[date] )
			    )
			)
		formatString: #,0
		displayFolder: Customer
		lineageTag: 1a3bc347-9f57-45f2-afd7-d401f627cfbe

	measure 'Returning Customers' =
			CALCULATE(
			    DISTINCTCOUNT( FCT_Sales[customer_key] ),
			    FILTER(
			        VALUES( FCT_Sales[customer_key] ),
			        VAR FirstPurchaseDate =
			            CALCULATE( MIN( FCT_Sales[order_date] ), ALL( 'DIM_Date' ) )
			        RETURN
			            FirstPurchaseDate < MIN( 'DIM_Date'[date] )
			    )
			)
		formatString: #,0
