table _measures
	lineageTag: 9452c871-433c-4553-9ec0-1fd4c4b98b20

	measure 'Active Stores' = CALCULATE( DISTINCTCOUNT( DIM_Store[store_code] ), DIM_Store[store_status] = "Open" )
		formatString: #,0
		displayFolder: Geography
		lineageTag: faf2c38b-5fbf-4fd9-8e8b-d709cf5c6cc4

	measure 'Gross Revenue' =
			
			SUMX( FCT_Sales, FCT_Sales[quantity] * FCT_Sales[unit_price] )
		formatString: #,0
		displayFolder: KPI - Sales
		lineageTag: 3864f6ec-b4b3-490c-9438-ea79216f1524

	measure 'Avg Order Value' =
			
			DIVIDE( [Net Revenue], [Orders] )
		formatString: #,0
		displayFolder: KPI - Sales
		lineageTag: 2b253de4-d5c1-4ff6-a346-402f12dfe2cd

	measure 'Line Items' =
			
			VAR Lines =
			    SUMMARIZE( FCT_Sales, FCT_Sales[order_number], FCT_Sales[line_number] )
			RETURN
			    COUNTROWS( Lines )
		formatString: #,0
		displayFolder: KPI - Sales
		lineageTag: a4844a3d-9c34-4559-baff-02afad5837e3

	measure 'Avg Line Items' =
			
			DIVIDE( [Line Items], [Orders] )
		formatString: #,0.0
		displayFolder: KPI - Sales
		lineageTag: e005c246-045e-4973-b668-58256212399e

	measure 'Orders SPLY' =
			VAR _AllSelected = COUNTROWS( 'DIM_Date' ) = CALCULATE( COUNTROWS( 'DIM_Date' ), ALL( 'DIM_Date' ) )
			RETURN IF( _AllSelected, BLANK(), udf.adaptfy.timeintellgence( [Orders], 'dim_date'[date], "SPLY" ) )
		formatString: #,0
		displayFolder: KPI - Time Intelligence
		lineageTag: 24115dae-b5ea-42af-900c-381d7ea38ab4

	measure 'Orders Delta' =
			VAR _TotalDates    = CALCULATE( COUNTROWS( 'DIM_Date' ), ALL( 'DIM_Date' ) )
			VAR _AllSelected   = COUNTROWS( 'DIM_Date' ) = _TotalDates
			RETURN IF( _AllSelected, 0, udf.adaptfy.timeintellgence( [Orders], 'dim_date'[date], "DELTA" ) )
		formatString: #,0
		displayFolder: KPI - Time Intelligence
		lineageTag: 20d3e1e7-6a17-4882-bf35-b7c554d99a6f

	measure 'Orders Delta %' =
