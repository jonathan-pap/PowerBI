	measure Customers =
			
			DISTINCTCOUNT( DIM_Customer[customer_key] )
		formatString: #,0
		displayFolder: Customer
		lineageTag: 31d810bc-e553-408e-81a7-700cf58a780e

	measure 'Average Age' =
			
			AVERAGE( DIM_Customer[age] )
		formatString: #,0.0
		displayFolder: Customer
		lineageTag: 8fa88e1c-5e1a-4543-b5fd-eca08708718f

	measure 'Revenue per Customer' = DIVIDE( [Net Revenue], DISTINCTCOUNT( FCT_Sales[customer_key] ) )
		formatString: #,0
		displayFolder: Customer
		lineageTag: 47983de3-d642-49c7-a2ef-fca38e95da06

	measure 'Repeat Rate' =
			
			VAR T =
			    SUMMARIZE(
			        FCT_Sales,
			        FCT_Sales[customer_key],
			        "Orders", DISTINCTCOUNT( FCT_Sales[order_number] )
			    )
			RETURN
			    DIVIDE(
			        COUNTROWS( FILTER( T, [Orders] >= 2 ) ),
			        COUNTROWS( T )
			    )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Customer
		lineageTag: 1bcdbf15-9f52-4285-98c4-f7364015a2bb

	measure 'Unique Products' =
			
