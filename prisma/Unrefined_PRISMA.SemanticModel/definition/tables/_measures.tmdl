	measure 'Revenue per Store' =
			DIVIDE(
			    [Physical Revenue],
			    CALCULATE( DISTINCTCOUNT( DIM_Store[store_code] ), DIM_Store[channel] = "Physical", DIM_Store[store_status] = "Open" )
