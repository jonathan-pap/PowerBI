			RETURN IF( _AllSelected, 0, udf.adaptfy.timeintellgence( [Orders], 'dim_date'[date], "PCT" ) )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: KPI - Time Intelligence
		lineageTag: f8005450-11bc-4b89-849a-293596b0523b

