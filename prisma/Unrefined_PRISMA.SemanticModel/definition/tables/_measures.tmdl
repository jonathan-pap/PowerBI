		lineageTag: 49b67028-fefb-433e-913b-c5d8af71372f

	measure 'Revenue per Sq Meter' =
			DIVIDE(
			    [Physical Revenue],
			    CALCULATE( SUM( DIM_Store[square_meters] ), DIM_Store[channel] = "Physical", DIM_Store[store_status] = "Open" )
			)
		formatString: #,0.00
		displayFolder: Geography
		lineageTag: 1dcbc75e-a72e-4d40-b8d0-52f663438d80

	measure 'Sales Amount USD' =
			
			SUMX(
			    FCT_Sales,
			    FCT_Sales[quantity] * FCT_Sales[net_price] * FCT_Sales[exchange_rate]
			)
		formatString: #,0
		isHidden
		displayFolder: Currency
		lineageTag: 849c3fc0-539d-4ff3-a180-8f36a8fe79be

		changedProperty = IsHidden

	measure 'Net Profit SPLY' =
			VAR _AllSelected = COUNTROWS( 'DIM_Date' ) = CALCULATE( COUNTROWS( 'DIM_Date' ), ALL( 'DIM_Date' ) )
			RETURN IF( _AllSelected, BLANK(), udf.adaptfy.timeintellgence( [Net Profit], 'dim_date'[date], "SPLY" ) )
		formatString: #,0
		displayFolder: KPI - Time Intelligence
		lineageTag: 95c1be3d-f3ea-4213-adf1-9dc337209127

	measure 'Margin % SPLY' =
			VAR _AllSelected = COUNTROWS( 'DIM_Date' ) = CALCULATE( COUNTROWS( 'DIM_Date' ), ALL( 'DIM_Date' ) )
			RETURN IF( _AllSelected, BLANK(), udf.adaptfy.timeintellgence( [Margin %], 'dim_date'[date], "SPLY" ) )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: KPI - Time Intelligence
		lineageTag: 1c5116c2-2c5f-41ca-a32a-82eb6cd3eb5d

	measure 'Margin Delta pp' =
			VAR _TotalDates  = CALCULATE( COUNTROWS( 'DIM_Date' ), ALL( 'DIM_Date' ) )
			VAR _AllSelected = COUNTROWS( 'DIM_Date' ) = _TotalDates
			VAR MarginNow    = [Margin %]
			VAR MarginPrior  = udf.adaptfy.timeintellgence( [Margin %], 'dim_date'[date], "SPLY" )
			RETURN
			    IF(
			        _AllSelected,
			        0,
			        IF(
			            NOT ISBLANK( MarginNow ) && NOT ISBLANK( MarginPrior ),
			            ( MarginNow - MarginPrior ) * 100
			        )
			    )
		formatString: 0.00 "pp";-0.00 "pp";0.00 "pp"
		displayFolder: KPI - Time Intelligence
		lineageTag: 7fb52cfa-0ecd-4600-945e-faff4215cbb4

		annotation PBI_FormatHint = {"isCustom":true}

