{
  "name": "Seppirus Dark Mode 1.1",
  "dataColors": [
    "#018DA2",
    "#00DEFF",
    "#C3F4FB",
    "#3E72A2",
    "#0084FD",
    "#A2D0FA",
    "#00F9B7",
    "#30A787"
  ],
  "background": "#31394C",
  "foreground": "#FFFFFF",
