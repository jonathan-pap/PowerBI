                "color": "#FFFFFF"
              }
            }
          }
        ],
        "visualTooltip": [
          {
            "titleFontColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "valueFontColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "background": {
              "solid": {
                "color": "#31394C"
              }
            }
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": {
              "solid": {
                "color": "#31394C"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ],
        "filterCard": [
          {
            "$id": "Applied",
            "backgroundColor": {
              "solid": {
                "color": "#F2F2F2"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#31394C"
              }
            },
            "transparency": 0
