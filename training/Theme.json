{
    "name": "Divergent",
    "$schema": "https://raw.githubusercontent.com/microsoft/powerbi-desktop-samples/refs/heads/main/Report%20Theme%20JSON%20Schema/reportThemeSchema-2.152.json",
    "dataColors": [
        "#B73A3A",
        "#EC5656",
        "#F28A90",
        "#F8BCBD",
        "#99E472",
        "#23C26F",
        "#0AAC00",
        
        "#026645",
        "#D48989",
        "#F49A9A",
        "#F7B9BC",
        "#FBD7D7",
        "#C2EFAA",
        "#7BDAA9",
        "#6CCD66",
        "#67A38F",
        "#892C2C",
        "#B14141",
        "#B6686C",
        "#BA8D8E",
        "#73AB56",
        "#1A9253",
        "#088100",
        "#024D34",
        "#475052",
        "#6A9FB0",
        "#BD7150",
        "#7B4F71",
        "#1B4D5C",
        "#706060",
        "#0F5C55",
        "#1C2325"
    ],
    "foreground": "#252423",
    "background": "#F4F4F4",
    "tableAccent": "#B73A3A",
    "maximum": "#B73A3A",
    "center": "#026645",
    "minimum": "#D2D3D5",
    "textClasses": {
        "title": {
            "fontFace": "Trebuchet MS"
        },
        "callout": {
            "fontFace": "Trebuchet MS"
        },
        "label": {
            "fontFace": "Trebuchet MS"
        },
        "header": {
            "fontFace": "Trebuchet MS"
        }
        
    },
    
    "visualStyles": {
        "*": {
            "*": {
                "visualHeader": [
                    {
                        "border": {
                            "solid": {
                                "color": "#F4F4F4"
                            }
                        },
                        "background": {
                            "solid": {
                                "color": "#F4F4F4"
                            }
                        }
                    }
                ],
                "background": [
                    {
                        "color": {
                            "solid": {
                                "color": "#F4F4F4"
                            }
                        }
                    }
                ],
                "outspacePane": [
                    {
                        "backgroundColor": {
                            "solid": {
                                "color": "#F4F4F4"
                            }
                        }
                    }
                ],
                "filterCard": [
                    {
                        "$id": "Applied",
                        "backgroundColor": {
                            "solid": {
                                "color": "#E6E6E6"
                            }
                        }
                    },
                    {
                        "$id": "Available",
                        "transparency": 100
                    }
                ]
            }
        },
        "slicer": {
            "*": {
                "items": [
                    {
                        "background": {
                            "solid": {
                                "color": "#F4F4F4"
                            }
                        }
                    }
                ]
            }
        },
        
        "page": {
            "*": {
                "outspace": [
                    {
                        "color": {
                            "solid": {
                                "color": "#F4F4F4"
                            }
                        }
                    },
                    {
                        "transparency": 100
                    }
                ]
            }
        }
    }
}