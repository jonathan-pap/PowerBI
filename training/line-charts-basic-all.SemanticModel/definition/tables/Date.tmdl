	partition Date = calculated
		mode: import
		source = ```
				
				
				VAR _StartDate = MIN ( 'Table'[Date] )
				VAR _LatestDate = MAX(  'Table'[Date] )
				VAR _EndDate = DATE( YEAR( _LatestDate ), 12, 31 )
				VAR _BaseCalendar = CALENDAR( _StartDate, _EndDate )
				VAR _Beltalowda = 
				    ADDCOLUMNS(
				        _BaseCalendar,
				        "Year (#)", YEAR( [Date] ), 
				        "Quarter (Q#)", "Q" & QUARTER( [Date] ),
				        "Quarter (#)", QUARTER( [Date] ),
				        "Month (MMM)", FORMAT( [Date], "MMM" ),
				        "Month (#)", MONTH( [Date] )
				    )
				VAR _Welwalla = 
				    ADDCOLUMNS(
				        _Beltalowda,
				        "IsLatestMonth", [Month (#)] = MONTH ( _LatestDate ),
				        "LatestMonthName", IF ( [Month (#)] = MONTH ( _LatestDate ), "Aug", " " ),
				        "OtherMonthNames", IF ( [Month (#)] = MONTH ( _LatestDate ), " ", [Month (MMM)] )
				    )
				RETURN
				_Welwalla
				```

	annotation PBI_Id = 011f28963b06425eaf162294fa163456

