		sourceColumn: [IsThisYear (True/False)]

		annotation SummarizationSetBy = Automatic

	partition Date = calculated
		mode: import
		source =
				
				VAR _LatestDate = MAX ( 'Table'[Month] )
				RETURN
				    ADDCOLUMNS (
				        CALENDAR (
				            DATE ( 2022, 1, 1 ),
				            DATE ( 2023, 12, 31 )
				        ),
				        "Year (YYYY)", YEAR ( ''[Date] ),
				        "Month Year (MMYYYY)",
				            FORMAT ( ''[Date], "MMYYYY" ),
				        "Month (MM)", MONTH ( ''[Date] ),
				        "Month (MMM)", FORMAT ( ''[Date], "MMM" ),
				        "DatesWithSales (True/False)",
				            ''[Date] < _LatestDate,
				        "IsThisYear (True/False)",
				            YEAR ( ''[Date] ) = YEAR ( _LatestDate )
				    )

	annotation PBI_Id = 163d92fff6ed49ff9051b07d98c0444d

