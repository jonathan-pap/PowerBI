	measure 'Icon Grid' = ```
			
			VAR _color       = SELECTEDVALUE( 'Color Pallette'[SvgSafe] )
			VAR _size        = 24
			VAR _pad         = 4
			VAR _boxSize     = _size + (_pad * 2)
			VAR _gap         = 8
			VAR _cell        = _boxSize + _gap
			VAR _cols        = 5
			VAR _rowsPerPage = 5
			VAR _perPage     = _cols * _rowsPerPage
			
			// ── Pagination ──────────────────────────────────────────────
			VAR _page        = SELECTEDVALUE( IconPages[PageNumber], 1 )
			VAR _startIdx    = (_page - 1) * _perPage
			
			// ── Get all icons sorted, with an index ─────────────────────
			VAR _sorted =
			    TOPN(
			        _perPage,
			        FILTER(
			            ADDCOLUMNS(
			                SUMMARIZE( 'Icons', 'Icons'[IconName], 'Icons'[PathData], 'Icons'[ViewBox] ),
			                "@rank",
			                    RANKX(
			                        ALLSELECTED( 'Icons' ),
			                        'Icons'[IconName], , ASC, DENSE
			                    ) - 1
			            ),
			            [@rank] >= _startIdx && [@rank] < _startIdx + _perPage
			        ),
			        [@rank], ASC
			    )
			
			// ── Count on this page ──────────────────────────────────────
			VAR _onPage    = COUNTROWS( _sorted )
			VAR _gridRows  = CEILING( _onPage / _cols, 1 )
			VAR _width     = (_cell * _cols) - _gap
			VAR _gridH     = (_cell * _gridRows) - _gap
			
			// ── Prompt when no color selected ───────────────────────────
			VAR _prompt =
			    "data:image/svg+xml;utf8, " &
			    "<svg xmlns='http://www.w3.org/2000/svg' width='" & _width & "' height='32'>" &
			    "<rect width='" & _width & "' height='32' rx='4' fill='%230D1B33'/>" &
			    "<text x='" & (_width / 2) & "' y='18' font-family='Segoe UI' font-size='10' " &
			        "fill='%23C7D0E0' text-anchor='middle'>Select a color</text></svg>"
			
			// ── Build icon tiles ────────────────────────────────────────
			VAR _icons = 
			    CONCATENATEX(
			        _sorted,
			        VAR _localIdx = [@rank] - _startIdx
			        VAR _col = MOD( _localIdx, _cols )
			        VAR _row = INT( _localIdx / _cols )
			        VAR _x = _col * _cell
			        VAR _y = _row * _cell
			        VAR _colored = SUBSTITUTE( [PathData], "currentColor", _color )
			        RETURN
			            "<rect x='" & _x & "' y='" & _y & 
			                "' width='" & _boxSize & "' height='" & _boxSize & 
			                "' rx='3' fill='%23071326' stroke='%231D3152' stroke-width='0.5'/>" &
			            "<svg x='" & (_x + _pad) & "' y='" & (_y + _pad) & 
			                "' width='" & _size & "' height='" & _size & 
			                "' viewBox='" & [ViewBox] & "'>" &
			                _colored & 
			            "</svg>",
			        "",
			        [@rank], ASC
			    )
			
			VAR _svg =
			    "data:image/svg+xml;utf8, " &
			    "<svg xmlns='http://www.w3.org/2000/svg' width='" & _width & "' height='" & _gridH & "'>" &
			        _icons &
			    "</svg>"
			
			RETURN
			    IF( ISBLANK( _color ), _prompt, _svg )
			```
		lineageTag: 45fb97d0-4f0a-4866-a82d-7935d249ea98
		dataCategory: ImageUrl

	measure 'In Page'
		lineageTag: 6221b9e9-7a60-44a0-9fa2-4d3c8998a3f4

	measure 'Show Page' =
			
			VAR _perPage    = 12 * 8  // must match your Icon Grid measure
			VAR _iconCount  = COUNTROWS( ALLSELECTED( 'Icons' ) )
			VAR _totalPages = CEILING( _iconCount / _perPage, 1 )
			VAR _thisPage   = SELECTEDVALUE( IconPages[PageNum] )
			RETURN
			    IF( _thisPage <= _totalPages, 1, 0 )
		formatString: 0
		lineageTag: 539561ec-f0f4-4c44-8008-ef5e97f89ed6

	measure 'SVG Dynamic Size' = ```
			
			VAR _pathData  = MAX( 'Icons'[PathData] )
			VAR _viewBox   = MAX( 'Icons'[ViewBox] )
			
			// ── Dynamic parameters ──────────────────────────────────────
			VAR _color     = SELECTEDVALUE( 'Color Pallette'[SvgSafe], "%233F51B5" )
			VAR _size      = MAX( Size[DynamicSize])
			
			// ── Replace ALL color references ────────────────────────────
			/* 
			    Icons can have colors in three forms:
			    - fill='currentColor' or stroke='currentColor'
			    - fill='#HEXHEX' or stroke='#HEXHEX'  (raw hex)
			    - fill='%23HEXHEX' or stroke='%23HEXHEX' (already escaped)
			    We normalize all to the selected color.
			*/
			VAR _step1 = SUBSTITUTE( _pathData, "currentColor", _color )
			VAR _step2 = SUBSTITUTE( _step1, "stroke='currentColor'", "stroke='" & _color & "'" )
			
			// ── Catch any hardcoded hex colors ──────────────────────────
			// Replace known defaults: #3F51B5 (indigo), #000, #000000
			VAR _step3 = SUBSTITUTE( _step2, "%233F51B5", _color )
			VAR _step4 = SUBSTITUTE( _step3, "%23000000", _color )
			VAR _step5 = SUBSTITUTE( _step4, "%23000",    _color )
			
			// ── Also handle fill='none' stroke scenarios ────────────────
			// Keep fill='none' as-is, only recolor the stroke
			VAR _final = SUBSTITUTE( _step5, "stroke='%233F51B5'", "stroke='" & _color & "'" )
			
			// ── Build the SVG ───────────────────────────────────────────
			RETURN
			    "data:image/svg+xml;utf8, " &
			    "<svg xmlns='http://www.w3.org/2000/svg'" &
			    " width='" & _size & "'" &
			    " height='" & _size & "'" &
			    " viewBox='" & _viewBox & "'>" &
			    _final &
			    "</svg>"
			```
		lineageTag: 0e866663-c27e-4b16-8977-219bc68b6df3
		dataCategory: ImageUrl

	column SetName
		dataType: string
		lineageTag: 5a05763f-5405-40ca-85b0-0ec14303c89f
		summarizeBy: none
		sourceColumn: SetName

		annotation SummarizationSetBy = Automatic

	partition Setname = m
		mode: import
		source =
				let
				    // Get all available icon set prefixes
				    Collections = Json.Document(
				        Web.Contents("https://api.iconify.design/collections")
				    ),
				
				    // Convert the record keys to a table
				    SetNames = Record.FieldNames(Collections),
				
				    Result = Table.FromList(
				        SetNames,
				        Splitter.SplitByNothing(),
				        {"SetName"}
				    )
				in
				    Result

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

