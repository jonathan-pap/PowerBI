table Setname
	lineageTag: cfc1807e-27dd-4ff9-baec-de8d8cc2cafe

	measure 'Icon Builders Black' =
			
			VAR _pathData  = MAX( 'Icons'[PathData] )
			VAR _viewBox   = MAX( 'Icons'[ViewBox] )
			
			// ── Dynamic parameters ──────────────────────────────────────
			VAR _color = SELECTEDVALUE( 'Color Pallette'[Hex] )
			//VAR _color     = "#2e7d32"
			VAR _size      = "24"
			
			// ── Replace currentColor with actual color ──────────────────
			VAR _coloredPath = SUBSTITUTE( _pathData, "currentColor", _color )
			
			// ── Build the SVG ───────────────────────────────────────────
			VAR _svg =
			    "data:image/svg+xml;utf8, " &
			    "<svg xmlns='http://www.w3.org/2000/svg'" &
			    " width='" & _size & "'" &
			    " height='" & _size & "'" &
			    " viewBox='" & _viewBox & "'>" &
			    _coloredPath &
			    "</svg>"
			RETURN
			    _svg
		lineageTag: fb45418e-b328-47cd-bada-39cf93b1a157
		dataCategory: ImageUrl

