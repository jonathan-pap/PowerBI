		    #"Duplicated Column" = Table.DuplicateColumn(#"Changed Type1", "DataImage", "DataImage - Copy"),
		    #"Renamed Columns" = Table.RenameColumns(#"Duplicated Column",{{"DataImage - Copy", "Icon"}})
		in
